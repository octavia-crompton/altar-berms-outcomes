   "source": [
    "# ── PLS Variable Importance for Predicting Intactness ─────────────────────────\n",
    "# Which original predictor variables best predict Intact/Not-Intact?\n",
    "# PLS finds directions in X with maximum covariance with y, then reports:\n",
    "#   • VIP scores (Variable Importance in Projection) — VIP > 1 = important\n",
    "#   • Standardised regression coefficients — sign shows direction of effect\n",
    "#\n",
    "# Panels:\n",
    "#   A. VIP scores (horizontal bars, sorted), threshold line at VIP = 1\n",
    "#   B. Standardised PLS regression coefficients (same order), coloured by sign\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.cross_decomposition import PLSRegression\n",
    "\n",
    "_FS = 12\n",
    "\n",
    "# ── 1. Build feature matrix (same as PCA cell) ──────────────────────────────\n",
    "_pls_preds_num = [\"slope_200\", \"FA_30_max\", \"Shape_Leng\"]\n",
    "_pls_preds_cat = [\"Landform\", \"Texture\", \"Soil_Development\"]\n",
    "_pls_cols = _pls_preds_num + _pls_preds_cat\n",
    "\n",
    "_df_pls = df.dropna(subset=_pls_cols + [\"Intact\"]).copy()\n",
    "\n",
    "_tex_counts_p = _df_pls[\"Texture\"].value_counts()\n",
    "_top3_tex_p   = _tex_counts_p.nlargest(3).index.tolist()\n",
    "_df_pls       = _df_pls[_df_pls[\"Texture\"].isin(_top3_tex_p)].copy()\n",
    "print(f\"Top 3 textures: {_top3_tex_p}\")\n",
    "\n",
    "_X_num_p = _df_pls[_pls_preds_num].astype(float)\n",
    "_X_cat_p = pd.get_dummies(_df_pls[_pls_preds_cat], drop_first=True).astype(float)\n",
    "_X_p     = pd.concat([_X_num_p, _X_cat_p], axis=1).fillna(0)\n",
    "_feat_names_p = list(_X_p.columns)\n",
    "\n",
    "# ── Pretty labels ────────────────────────────────────────────────────────────\n",
    "_feat_labels_p = []\n",
    "for _fn in _feat_names_p:\n",
    "    _matched = False\n",
    "    for _prefix in _pls_preds_cat:\n",
    "        if _fn.startswith(_prefix + \"_\"):\n",
    "            _cat_val = _fn[len(_prefix) + 1:]\n",
    "            _pretty_prefix = PRETTY_LABELS.get(_prefix, _prefix)\n",
    "            _feat_labels_p.append(f\"{_pretty_prefix}: {_cat_val}\")\n",
    "            _matched = True\n",
    "            break\n",
    "    if not _matched:\n",
    "        _feat_labels_p.append(PRETTY_LABELS.get(_fn, _fn))\n",
    "\n",
    "_scaler_p   = StandardScaler()\n",
    "_X_scaled_p = _scaler_p.fit_transform(_X_p)\n",
    "_y_p        = _df_pls[\"Intact\"].astype(float).values\n",
    "\n",
    "print(f\"n = {_X_scaled_p.shape[0]} berms, {_X_scaled_p.shape[1]} features\")\n",
    "\n",
    "# ── 2. Fit PLS (2 components) ────────────────────────────────────────────────\n",
    "_n_comp = 2\n",
    "_pls = PLSRegression(n_components=_n_comp, scale=False)\n",
    "_pls.fit(_X_scaled_p, _y_p)\n",
    "\n",
    "# ── 3. VIP scores ────────────────────────────────────────────────────────────\n",
    "# VIP_j = sqrt( p * sum_a( SS_a * w_ja² ) / sum_a(SS_a) )\n",
    "# where w = x_weights_, SS_a = sum of squares explained by component a\n",
    "_W = _pls.x_weights_                       # (p, n_comp)\n",
    "_T = _pls.x_scores_                        # (n, n_comp)\n",
    "_Q = _pls.y_loadings_                      # (1, n_comp) for univariate y\n",
    "_p_feat = _X_scaled_p.shape[1]\n",
    "\n",
    "_SS = np.array([np.sum((_T[:, a] * _Q[0, a])**2) for a in range(_n_comp)])\n",
    "_vip = np.sqrt(_p_feat * np.sum(_SS * _W**2, axis=1) / np.sum(_SS))\n",
    "\n",
    "# ── 4. Standardised regression coefficients ──────────────────────────────────\n",
    "_coefs = _pls.coef_.ravel()   # (p,) — these are on the standardised X scale\n",
    "\n",
    "# ── 5. Sort by VIP descending ────────────────────────────────────────────────\n",
    "_sort_ord = np.argsort(_vip)[::-1]\n",
    "_vip_sorted   = _vip[_sort_ord]\n",
    "_coef_sorted  = _coefs[_sort_ord]\n",
    "_labels_sorted = [_feat_labels_p[i] for i in _sort_ord]\n",
    "\n",
    "# print ranked table\n",
    "print(f\"\\n{'Variable':<35s} {'VIP':>6s} {'Coef':>8s}\")\n",
    "print(\"─\" * 51)\n",
    "for _i, _si in enumerate(_sort_ord):\n",
    "    print(f\"{_labels_sorted[_i]:<35s} {_vip_sorted[_i]:6.3f} {_coef_sorted[_i]:+8.4f}\")\n",
    "\n",
    "# ── 6. Two-panel figure ──────────────────────────────────────────────────────\n",
    "_fig, (_ax_vip, _ax_coef) = plt.subplots(1, 2, figsize=(14, 5),\n",
    "                                          sharey=True)\n",
    "_fig.subplots_adjust(wspace=0.08)\n",
    "\n",
    "_y_pos = np.arange(len(_vip_sorted))\n",
    "\n",
    "# ── A: VIP scores ────────────────────────────────────────────────────────────\n",
    "_vip_colors = [MODEL_CLR_CONDITION if v >= 1.0 else \"#aaaaaa\"\n",
    "               for v in _vip_sorted]\n",
    "_ax_vip.barh(_y_pos, _vip_sorted, color=_vip_colors, edgecolor=\"white\",\n",
    "             height=0.7, zorder=3)\n",
    "_ax_vip.axvline(1.0, color=\"black\", lw=1.2, ls=\"--\", label=\"VIP = 1\")\n",
    "_ax_vip.set_yticks(_y_pos)\n",
    "_ax_vip.set_yticklabels(_labels_sorted, fontsize=_FS - 1)\n",
    "_ax_vip.set_xlabel(\"VIP score\", fontsize=_FS)\n",
    "_ax_vip.set_title(\"A  Variable Importance in Projection (VIP)\",\n",
    "                   fontsize=_FS, loc=\"left\")\n",
    "_ax_vip.legend(fontsize=_FS - 2)\n",
    "_ax_vip.tick_params(labelsize=_FS - 1)\n",
    "_ax_vip.grid(axis=\"x\", lw=0.4, alpha=0.4, zorder=0)\n",
    "_ax_vip.invert_yaxis()\n",
    "\n",
    "# ── B: Standardised regression coefficients ──────────────────────────────────\n",
    "_coef_colors = [INTACT_COL if c >= 0 else DEGRADED_COL for c in _coef_sorted]\n",
    "_ax_coef.barh(_y_pos, _coef_sorted, color=_coef_colors, edgecolor=\"white\",\n",
    "              height=0.7, zorder=3)\n",
    "_ax_coef.axvline(0, color=\"black\", lw=0.8)\n",
    "_ax_coef.set_xlabel(\"Standardised PLS coefficient\", fontsize=_FS)\n",
    "_ax_coef.set_title(\"B  Direction of effect on Intactness\",\n",
    "                    fontsize=_FS, loc=\"left\")\n",
    "_ax_coef.tick_params(labelsize=_FS - 1)\n",
    "_ax_coef.grid(axis=\"x\", lw=0.4, alpha=0.4, zorder=0)\n",
    "_ax_coef.invert_yaxis()\n",
    "\n",
    "# legend for coefficient sign\n",
    "from matplotlib.patches import Patch\n",
    "_ax_coef.legend(handles=[Patch(facecolor=INTACT_COL, label=\"Promotes intactness\"),\n",
    "                          Patch(facecolor=DEGRADED_COL, label=\"Reduces intactness\")],\n",
    "                fontsize=_FS - 2, loc=\"lower right\")\n",
    "\n",
    "_fig.suptitle(\n",
    "    f\"PLS predictor importance for Intactness  \"\n",
    "    f\"(n = {_X_scaled_p.shape[0]},  {_n_comp} components)\",\n",
    "    fontsize=_FS + 1, y=1.02)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# ── PLS Variable Importance for Predicting Vegetation-Response Effectiveness ───\n",
    "# Mirror of the intactness PLS above, but y = effective (effect_percent > 7).\n",
    "# Filtered to measured berms only (effect_percent not NaN).\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from matplotlib.patches import Patch\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.cross_decomposition import PLSRegression\n",
    "\n",
    "_FS = 12\n",
    "\n",
    "# ── 1. Build feature matrix — measured berms only ────────────────────────────\n",
    "_pls_preds_num_e = [\"slope_200\", \"FA_30_max\", \"Shape_Leng\"]\n",
    "_pls_preds_cat_e = [\"Landform\", \"Texture\", \"Soil_Development\"]\n",
    "_pls_cols_e = _pls_preds_num_e + _pls_preds_cat_e\n",
    "\n",
    "_df_pls_e = df.dropna(subset=_pls_cols_e + [\"effect_percent\"]).copy()\n",
    "\n",
    "_tex_counts_e = _df_pls_e[\"Texture\"].value_counts()\n",
    "_top3_tex_e   = _tex_counts_e.nlargest(3).index.tolist()\n",
    "_df_pls_e     = _df_pls_e[_df_pls_e[\"Texture\"].isin(_top3_tex_e)].copy()\n",
    "print(f\"Top 3 textures: {_top3_tex_e}\")\n",
    "\n",
    "# Binary effectiveness flag: effective if effect_percent > 7 %\n",
    "_y_e = (_df_pls_e[\"effect_percent\"] > 7).astype(float).values\n",
    "print(f\"n = {len(_y_e)} measured berms  |  \"\n",
    "      f\"effective: {int(_y_e.sum())}  ({_y_e.mean()*100:.1f}%)\")\n",
    "\n",
    "_X_num_e = _df_pls_e[_pls_preds_num_e].astype(float)\n",
    "_X_cat_e = pd.get_dummies(_df_pls_e[_pls_preds_cat_e], drop_first=True).astype(float)\n",
    "_X_e     = pd.concat([_X_num_e, _X_cat_e], axis=1).fillna(0)\n",
    "_feat_names_e = list(_X_e.columns)\n",
    "\n",
    "# ── Pretty labels ─────────────────────────────────────────────────────────────\n",
    "_feat_labels_e = []\n",
    "for _fn in _feat_names_e:\n",
    "    _matched = False\n",
    "    for _prefix in _pls_preds_cat_e:\n",
    "        if _fn.startswith(_prefix + \"_\"):\n",
    "            _cat_val = _fn[len(_prefix) + 1:]\n",
    "            _pretty_prefix = PRETTY_LABELS.get(_prefix, _prefix)\n",
    "            _feat_labels_e.append(f\"{_pretty_prefix}: {_cat_val}\")\n",
    "            _matched = True\n",
    "            break\n",
    "    if not _matched:\n",
    "        _feat_labels_e.append(PRETTY_LABELS.get(_fn, _fn))\n",
    "\n",
    "_scaler_e    = StandardScaler()\n",
    "_X_scaled_e  = _scaler_e.fit_transform(_X_e)\n",
    "\n",
    "# ── 2. Fit PLS (2 components) ─────────────────────────────────────────────────\n",
    "_n_comp_e = 2\n",
    "_pls_e = PLSRegression(n_components=_n_comp_e, scale=False)\n",
    "_pls_e.fit(_X_scaled_e, _y_e)\n",
    "\n",
    "# ── 3. VIP scores ────────────────────────────────────────────────────────────\n",
    "_W_e = _pls_e.x_weights_\n",
    "_T_e = _pls_e.x_scores_\n",
    "_Q_e = _pls_e.y_loadings_\n",
    "_p_e = _X_scaled_e.shape[1]\n",
    "\n",
    "_SS_e = np.array([np.sum((_T_e[:, a] * _Q_e[0, a])**2) for a in range(_n_comp_e)])\n",
    "_vip_e = np.sqrt(_p_e * np.sum(_SS_e * _W_e**2, axis=1) / np.sum(_SS_e))\n",
    "\n",
    "# ── 4. Standardised regression coefficients ───────────────────────────────────\n",
    "_coefs_e = _pls_e.coef_.ravel()\n",
    "\n",
    "# ── 5. Sort by VIP descending ─────────────────────────────────────────────────\n",
    "_sort_e = np.argsort(_vip_e)[::-1]\n",
    "_vip_sorted_e   = _vip_e[_sort_e]\n",
    "_coef_sorted_e  = _coefs_e[_sort_e]\n",
    "_labels_sorted_e = [_feat_labels_e[i] for i in _sort_e]\n",
    "\n",
    "print(f\"\\n{'Variable':<35s} {'VIP':>6s} {'Coef':>8s}\")\n",
    "print(\"─\" * 51)\n",
    "for _i in range(len(_sort_e)):\n",
    "    print(f\"{_labels_sorted_e[_i]:<35s} {_vip_sorted_e[_i]:6.3f} {_coef_sorted_e[_i]:+8.4f}\")\n",
    "\n",
    "# ── 6. Two-panel figure ───────────────────────────────────────────────────────\n",
    "_fig_e, (_ax_vip_e, _ax_coef_e) = plt.subplots(1, 2, figsize=(14, 5), sharey=True)\n",
    "_fig_e.subplots_adjust(wspace=0.08)\n",
    "\n",
    "_y_pos_e = np.arange(len(_vip_sorted_e))\n",
    "\n",
    "# ── A: VIP scores ─────────────────────────────────────────────────────────────\n",
    "_vip_colors_e = [MODEL_CLR_VEGRESPONSE if v >= 1.0 else \"#aaaaaa\"\n",
    "                 for v in _vip_sorted_e]\n",
    "_ax_vip_e.barh(_y_pos_e, _vip_sorted_e, color=_vip_colors_e, edgecolor=\"white\",\n",
    "               height=0.7, zorder=3)\n",
    "_ax_vip_e.axvline(1.0, color=\"black\", lw=1.2, ls=\"--\", label=\"VIP = 1\")\n",
    "_ax_vip_e.set_yticks(_y_pos_e)\n",
    "_ax_vip_e.set_yticklabels(_labels_sorted_e, fontsize=_FS - 1)\n",
    "_ax_vip_e.set_xlabel(\"VIP score\", fontsize=_FS)\n",
    "_ax_vip_e.set_title(\"A  Variable Importance in Projection (VIP)\",\n",
    "                     fontsize=_FS, loc=\"left\")\n",
    "_ax_vip_e.legend(fontsize=_FS - 2)\n",
    "_ax_vip_e.tick_params(labelsize=_FS - 1)\n",
    "_ax_vip_e.grid(axis=\"x\", lw=0.4, alpha=0.4, zorder=0)\n",
    "_ax_vip_e.invert_yaxis()\n",
    "\n",
    "# ── B: Standardised regression coefficients ───────────────────────────────────\n",
    "_coef_colors_e = [CLR_EFF if c >= 0 else CLR_CHANCE for c in _coef_sorted_e]\n",
    "_ax_coef_e.barh(_y_pos_e, _coef_sorted_e, color=_coef_colors_e, edgecolor=\"white\",\n",
    "                height=0.7, zorder=3)\n",
    "_ax_coef_e.axvline(0, color=\"black\", lw=0.8)\n",
    "_ax_coef_e.set_xlabel(\"Standardised PLS coefficient\", fontsize=_FS)\n",
    "_ax_coef_e.set_title(\"B  Direction of effect on Effectiveness\",\n",
    "                      fontsize=_FS, loc=\"left\")\n",
    "_ax_coef_e.tick_params(labelsize=_FS - 1)\n",
    "_ax_coef_e.grid(axis=\"x\", lw=0.4, alpha=0.4, zorder=0)\n",
    "_ax_coef_e.invert_yaxis()\n",
    "_ax_coef_e.legend(\n",
    "    handles=[Patch(facecolor=CLR_EFF,    label=\"Promotes effectiveness\"),\n",
    "             Patch(facecolor=CLR_CHANCE, label=\"Reduces effectiveness\")],\n",
    "    fontsize=_FS - 2, loc=\"lower right\")\n",
    "\n",
    "_fig_e.suptitle(\n",
    "    f\"PLS predictor importance for Vegetation-Response Effectiveness  \"\n",
    "    f\"(n = {len(_y_e)},  {_n_comp_e} components)\\n\"\n",
    "    f\"Effective = effect_percent > 7%  \"\n",
    "    f\"({int(_y_e.sum())} / {len(_y_e)} berms)\",\n",
    "    fontsize=_FS + 1, y=1.02)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
