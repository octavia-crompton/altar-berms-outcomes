	author = {Watanabe, Shuntaro and Sumi, Kazuaki and Ise, Takeshi},
	month = nov,
	year = {2020},
	keywords = {Convolutional neural network, Google earth imagery, Vegetation mapping, google earth imagery},
	pages = {65},
}

