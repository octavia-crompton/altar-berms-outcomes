	abstract = {In this millennium, global drylands face a myriad of problems that present tough research, management, and policy challenges. Recent advances in dryland development, however, together with the integrative approaches of global change and sustainability science, suggest that concerns about land degradation, poverty, safeguarding biodiversity, and protecting the culture of 2.5 billion people can be confronted with renewed optimism. We review recent lessons about the functioning of dryland ecosystems and the livelihood systems of their human residents and introduce a new synthetic framework, the Drylands Development Paradigm (DDP). The DDP, supported by a growing and well-documented set of tools for policy and management action, helps navigate the inherent complexity of desertification and dryland development, identifying and synthesizing those factors important to research, management, and policy communities.},
	language = {en},
	number = {5826},
	urldate = {2022-02-19},
	journal = {Science},
	author = {Reynolds, James F. and Smith, D. Mark Stafford and Lambin, Eric F. and Turner, B. L. and Mortimore, Michael and Batterbury, Simon P. J. and Downing, Thomas E. and Dowlatabadi, Hadi and Fernández, Roberto J. and Herrick, Jeffrey E. and Huber-Sannwald, Elisabeth and Jiang, Hong and Leemans, Rik and Lynam, Tim and Maestre, Fernando T. and Ayarza, Miguel and Walker, Brian},
	month = may,
	year = {2007},
	pages = {847--851},
}

@incollection{camici_chapter_2019,
	title = {Chapter {Ten} - {Recent} advances in remote sensing of precipitation and soil moisture products for riverine flood prediction},
	isbn = {978-0-12-814899-0},
	url = {https://www.sciencedirect.com/science/article/pii/B9780128148990000109},
	abstract = {In this chapter the recent advances in remote sensing for flood prediction are discussed. Remote sensing methods are providing different datasets and products, useful for improving our capability of monitoring and predicting floods. Two fundamental variables for the prediction of floods are analyzed: precipitation and soil moisture. The challenges and future directions to be addressed for the full exploitation of these satellite products are identified. The chapter further underlines the need of making scientists and end-users aware of the availability and potential of satellite observations and of fostering a closed collaboration between the remote sensing community (data developers) and the data user communities (e.g., hydrologists, agronomists).},
	language = {en},
	urldate = {2022-02-18},
	booktitle = {Extreme {Hydroclimatic} {Events} and {Multivariate} {Hazards} in a {Changing} {Environment}},
	publisher = {Elsevier},
