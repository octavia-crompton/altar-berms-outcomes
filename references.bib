@article{brirhet_comparison_2016,
	title = {Comparison {Of} {Two} {Hydrological} {Models} ({Lumped} {And} {Distributed}) {Over} {A} {Pilot} {Area} {Of} {The} {Issen} {Watershed} {In} {The} {Souss} {Basin}, {Morocco}},
